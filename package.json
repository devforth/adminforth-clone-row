{
  "name": "@adminforth/clone-row",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/clone-row/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "keywords": [
    "adminforth",
    "record-cloning",
    "row-duplication",
    "list-actions",
    "form-prefill",
    "productivity"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "description": "Record cloning plugin for AdminForth with one-click row duplication",
  "devDependencies": {
    "@types/node": "latest",
    "adminforth": "^2.42.0",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "adminforth": "^2.42.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/clone-row",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ]
  },
  "branches": [
    "main",
    {
      "name": "next",
      "prerelease": true
    }
  ]
}
